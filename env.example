# ============================================
# Dent Ops OS Frontend - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp env.example .env.local

# ============================================
# API Configuration
# ============================================
# Backend API URL (default: http://localhost:3001)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public app URL for metadata / custom domain (e.g. https://ops.denteducation.org)
NEXT_PUBLIC_APP_URL=

# ============================================
# Firebase Configuration (Already configured in lib/firebase.ts)
# ============================================
# Firebase config is hardcoded in src/lib/firebase.ts
# If you need to change it, edit that file directly

# ============================================
# Demo accounts (login page review buttons)
# ============================================
# Opt-out: omit or set true to show Admin / SS / Coach / Student demo buttons.
# Backend must also allow demo (DEMO_MODE_ENABLED unset or true; set false to disable).
NEXT_PUBLIC_DEMO_MODE_ENABLED=true
