# ============================================
# Dent Ops OS Frontend - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp env.example .env.local

# ============================================
# API Configuration
# ============================================
# Backend API URL (default: http://localhost:3001)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public app URL for metadata / custom domain (e.g. https://ops.denteducation.org)
NEXT_PUBLIC_APP_URL=

# ============================================
# BoB Key Links (staff resource URLs)
# Set these on Vercel for production — staff see them on Key Links page.
# ============================================
# Example: https://drive.google.com/drive/folders/YOUR_FOLDER_ID
NEXT_PUBLIC_BOB_KEY_LINK_SYP_DRIVE=
# Example: https://drive.google.com/drive/folders/YOUR_CURRICULUM_ID
NEXT_PUBLIC_BOB_KEY_LINK_CURRICULUM=
# Example: https://photos.google.com/share/YOUR_ALBUM_ID
NEXT_PUBLIC_BOB_KEY_LINK_PHOTO_ALBUM=
# Example: https://yourworkspace.slack.com
NEXT_PUBLIC_BOB_KEY_LINK_SLACK=
# Example: https://groups.google.com/...
NEXT_PUBLIC_BOB_KEY_LINK_EMAIL_GROUPS=

# ============================================
# Firebase Configuration (Already configured in lib/firebase.ts)
# ============================================
# Firebase config is hardcoded in src/lib/firebase.ts
# If you need to change it, edit that file directly
